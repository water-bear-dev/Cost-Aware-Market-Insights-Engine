# --- Environment Detection ---
# Set to 'production' to auto-switch to AWS Bedrock
ENVIRONMENT=local

# --- LLM Configuration ---
# Options: mock, ollama, bedrock
# If ENVIRONMENT=production, this defaults to bedrock unless overridden
LLM_PROVIDER=ollama

# Ollama Settings (for local)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Bedrock Settings (for cloud)
AWS_DEFAULT_REGION=us-east-1

# --- FinOps & Budget ---
DAILY_BUDGET_USD=5.00

# --- Market Data ---
TICKERS=AAPL,MSFT,GOOGL,AMZN,META

# --- Database ---
# Leave empty in production to use real DynamoDB
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8001
